    {
      "title": "ましょう (Polite Suggestion) — N5 Review",
      "meaning": "একসাথে কিছু করার প্রস্তাব (Polite)",
      "note": "N5 Lesson 6 এ শেখা। ましょう হলো Polite form, いこうけい হলো Plain form।",
      "examples": [
        {
          "jpFuri": [
            { "kanji": "いっしょに", "furigana": "" },
            { "kanji": "ひるごはんを", "furigana": "" },
            { "kanji": "たべませんか。", "furigana": "" }
          ],
          "bn": "একসাথে [[দুপুরের খাবার খাবেন কি]]?"
        },
        {
          "jpFuri": [
            { "kanji": "ええ、", "furigana": "" },
            { "kanji": "たべましょう。", "furigana": "", "highlight": true }
          ],
          "bn": "হ্যাঁ, [[একসাথে খাই]]। (Polite)"
        }
      ],
      "effect": "ましょう — Polite ভাষায় 'let's do' বোঝায়। ませんか (negative question) দিয়ে সুন্দরভাবে প্রস্তাব করা হয়।"
    },
    {
      "title": "いこうけい (Volitional Form) — Plain Suggestion",
      "meaning": "একসাথে কিছু করার প্রস্তাব (Plain)",
      "note": "Polite いでしょう এর Plain রূপ। বন্ধুদের সাথে কথোপকথনে ব্যবহৃত হয়।",
      "conjugation": {
        "Group 1 (い line → お line + う)": "いきます → いこう / のみます → のもう",
        "Group 2 (ます → よう)": "たべます → たべよう",
        "Group 3 (します → しよう / きます → こよう)": "べんきょうします → べんきょうしよう"
      },
      "examples": [
        {
          "jpFuri": [
            { "kanji": "いっしょに", "furigana": "" },
            { "kanji": "ひるごはんを", "furigana": "" },
            { "kanji": "たべない？", "furigana": "" }
