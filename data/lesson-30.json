    {
      "title": "～て あります (Transitive Verb + Resultant State)",
      "meaning": "কোনো কাজ ইচ্ছাকৃতভাবে করা হয়েছে এবং তার ফলাফল বর্তমানে বিদ্যমান আছে",
      "note": "Intransitive Verb এর ক্ষেত্রে ～て います এবং Transitive Verb এর ক্ষেত্রে ～て あります ব্যবহৃত হয়",
      "examples": [
        {
          "jpFuri": [
            { "kanji": "つくえの", "furigana": "" },
            { "kanji": "うえに", "furigana": "" },
            { "kanji": "レポートを", "furigana": "" },
            { "kanji": "かいて あります", "furigana": "", "highlight": true }
          ],
          "bn": "ডেস্কের উপর [[রিপোর্টটি লেখা আছে]]।"
        },
        {
          "jpFuri": [
            { "kanji": "かべに", "furigana": "" },
            { "kanji": "ポスターが", "furigana": "" },
            { "kanji": "はって あります", "furigana": "", "highlight": true }
          ],
          "bn": "দেয়ালে [[পোস্টার লাগানো আছে]]। [Object: ポスターが]"
        },
        {
          "jpFuri": [
            { "kanji": "ポスターは", "furigana": "" },
            { "kanji": "かべに", "furigana": "" },
            { "kanji": "はって あります", "furigana": "", "highlight": true }
          ],
          "bn": "পোস্টার [[দেয়ালে লাগানো আছে]]। [Subject: ポスターは]"
        }
      ],
      "effect": "～て あります — Transitive Verb (他動詞) এর সাথে ব্যবহৃত হয়। ইচ্ছাকৃতভাবে কাজ করা হয়েছে এবং তার ফলাফল এখনো আছে।"
    },
    {
      "title": "Intransitive vs Transitive Verb + あります",
      "meaning": "Intransitive ও Transitive Verb এর পার্থক্য বোঝা",
      "note": "সঠিক বাক্য গঠনের জন্য Verb এর ধরন জানা জরুরি",
      "examples": [
        {
          "jpFuri": [
            { "kanji": "ドアが", "furigana": "" },
            { "kanji": "しまって います", "furigana": "", "highlight": true }
          ],
          "bn": "দরজা [[বন্ধ আছে]]। → Intransitive Verb (しまる)"
        },
        {
          "jpFuri": [
            { "kanji": "ドアが", "furigana": "" },
            { "kanji": "しめて あります", "furigana": "", "highlight": true }
          ],
          "bn": "দরজা [[বন্ধ করে রাখা হয়েছে]]। → Transitive Verb (しめる)"
        }
      ],
      "effect": "⚠️ ভুল: ドアが しまって あります। — Intransitive Verb এর সাথে ～てあります ব্যবহার করা যায় না।"
    },
