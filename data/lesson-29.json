    {
      "title": "～て います (Intransitive Verb + Resultant State)",
      "meaning": "অতীতে কোনো কাজ বা পরিবর্তন ঘটেছে এবং তার ফলাফল বর্তমানে বিদ্যমান আছে",
      "note": "এই ব্যবহারে সাধারণত Intransitive Verb (自動詞) ব্যবহৃত হয়",
      "examples": [
        {
          "jpFuri": [
            {
              "kanji": "まどが",
              "furigana": ""
            },
            {
              "kanji": "こわれて",
              "furigana": "",
              "highlight": true
            },
            {
              "kanji": "います",
              "furigana": ""
            }
